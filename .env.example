# ---------------------------------------------------------------------------
# PostePro — variables d'environnement
# Copiez ce fichier en `.env.local` (dev) et configurez les mêmes clés sur Vercel.
# ---------------------------------------------------------------------------

# URL canonique du site (sans slash final). Utilisée pour les balises canoniques,
# Open Graph, sitemap.xml et robots.txt.
NEXT_PUBLIC_SITE_URL=https://postepro.fr

# ---------------------------------------------------------------------------
# Stockage des leads (capture e-mail)
# ---------------------------------------------------------------------------
# Le code choisit automatiquement le provider :
#   - Si SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY sont définis  -> Supabase
#   - Sinon                                                     -> fichier local (dev)
#
# En production sur Vercel, le système de fichiers est éphémère : configurez
# Supabase (ou un autre provider via lib/leads) pour persister réellement.

# Supabase (recommandé en prod). Créez une table `leads` :
#   create table leads (
#     id uuid primary key default gen_random_uuid(),
#     email text not null,
#     ville text,
#     metier text,
#     source text,
#     created_at timestamptz not null default now()
#   );
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel : chemin du fichier de leads en local (dev).
# Par défaut : ./data/leads.ndjson (dev) ou un dossier temporaire (prod).
# LEADS_FILE=./data/leads.ndjson
